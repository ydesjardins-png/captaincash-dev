# ═══════════════════════════════════════════════════════════════
# Captain Cash — Apache .htaccess
# Drop this file at the document root alongside index.html
# Replicates all Netlify behaviour exactly:
#   - HTTPS redirect
#   - Directory-style URLs (/slug/ → /slug/index.html)
#   - 13 legacy .html redirects
#   - Cache headers for assets, HTML, sitemap
#   - Security headers
#   - WordPress /blog/ passthrough
# ═══════════════════════════════════════════════════════════════

# ── Engine on ────────────────────────────────────────────────────
Options -Indexes
RewriteEngine On

# ── 1. Force HTTPS ───────────────────────────────────────────────
#RewriteCond %{HTTPS} off
#RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ── 2. Force www (remove if you prefer non-www) ──────────────────
# Uncomment the block below if you want www.captaincash.ca canonical
# RewriteCond %{HTTP_HOST} !^www\. [NC]
# RewriteRule ^ https://www.%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ── 3. Pass /blog/ directly to WordPress ─────────────────────────
# WordPress has its own .htaccess in /blog/ — don't intercept it
#RewriteRule ^blog(/.*)?$ - [L]

# ── 4. Serve directory index files ───────────────────────────────
# /slug/ → /slug/index.html (core of the URL structure)
DirectoryIndex index.html

# ── 5. Legacy .html URL redirects (from netlify.toml) ────────────
# These preserve any inbound links to the old flat .html structure

Redirect 301 /claim-your-cash.html              /claim-your-cash/
Redirect 301 /renew-your-loan.html              /renew-your-loan/
Redirect 301 /online-payment.html               /online-payment/
Redirect 301 /how-it-works.html                 /how-does-it-work/
Redirect 301 /support.html                      /support/
Redirect 301 /about.html                        /about-us/
Redirect 301 /contact.html                      /contact-us/
Redirect 301 /testimonials.html                 /testimonials/
Redirect 301 /pages/bad-credit-loans.html       /bad-credit-loans-canada/
Redirect 301 /pages/installment-loans.html      /installment-loans-canada/
Redirect 301 /pages/no-credit-check-loans.html  /no-credit-check-loans-canada/
Redirect 301 /pages/payday-loans.html           /payday-loans/
Redirect 301 /pages/loans-canada.html           /loans-in-canada/

# ── 6. Trailing slash enforcement ────────────────────────────────
# /slug → /slug/ (canonical trailing slash — matches Netlify behaviour)
# Only applies to paths that are not real files
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} !/$
RewriteCond %{REQUEST_URI} !\.(html|css|js|webp|avif|png|jpg|jpeg|gif|svg|ico|woff2|woff|ttf|pdf|xml|txt)$
RewriteRule ^(.+)$ /$1/ [L,R=301]

# ── 7. Clean URL rewrite (/slug/ → /slug/index.html) ─────────────
# Handles the actual serving — no redirect, internal rewrite only
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ $1/index.html [L]

# ── 8. Custom 404 page ───────────────────────────────────────────
ErrorDocument 404 /404.html

# ═══════════════════════════════════════════════════════════════
# CACHE HEADERS — mirrors netlify.toml exactly
# ═══════════════════════════════════════════════════════════════

<IfModule mod_expires.c>
  ExpiresActive On

  # Fonts — 1 year immutable
  <FilesMatch "\.(woff2|woff|ttf|otf)$">
    ExpiresDefault "access plus 1 year"
  </FilesMatch>

  # Images — 1 year immutable
  <FilesMatch "\.(webp|avif|png|jpg|jpeg|gif|svg|ico)$">
    ExpiresDefault "access plus 1 year"
  </FilesMatch>

  # CSS and JS — 1 year immutable
  <FilesMatch "\.(css|js)$">
    ExpiresDefault "access plus 1 year"
  </FilesMatch>

  # HTML — no cache (deploy immediately)
  <FilesMatch "\.html$">
    ExpiresDefault "access plus 0 seconds"
  </FilesMatch>

  # Sitemap and robots — 1 day
  <FilesMatch "^(sitemap\.xml|robots\.txt)$">
    ExpiresDefault "access plus 1 day"
  </FilesMatch>
</IfModule>

<IfModule mod_headers.c>

  # Fonts — immutable
  <FilesMatch "\.(woff2|woff|ttf|otf)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Images — immutable
  <FilesMatch "\.(webp|avif|png|jpg|jpeg|gif|svg|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # CSS and JS — immutable
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # HTML — must revalidate on every request
  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>

  # Sitemap and robots — 1 day
  <FilesMatch "^(sitemap\.xml|robots\.txt)$">
    Header set Cache-Control "public, max-age=86400"
  </FilesMatch>

  # ── Security headers (all requests) ──────────────────────────
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"

  # HSTS — tells browsers to always use HTTPS (6 months)
  # Uncomment once HTTPS is fully confirmed stable on Apache
  # Header always set Strict-Transport-Security "max-age=15768000; includeSubDomains"

</IfModule>

# ═══════════════════════════════════════════════════════════════
# COMPRESSION — speeds up delivery (especially for HTML/CSS/JS)
# ═══════════════════════════════════════════════════════════════

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css
  AddOutputFilterByType DEFLATE application/javascript text/javascript
  AddOutputFilterByType DEFLATE application/json text/xml application/xml
  AddOutputFilterByType DEFLATE image/svg+xml
  AddOutputFilterByType DEFLATE font/woff2 font/woff
</IfModule>

# ═══════════════════════════════════════════════════════════════
# MIME TYPES — ensure correct types for modern formats
# ═══════════════════════════════════════════════════════════════

<IfModule mod_mime.c>
  AddType image/webp         .webp
  AddType image/avif         .avif
  AddType font/woff2         .woff2
  AddType font/woff          .woff
  AddType application/json   .json
</IfModule>
